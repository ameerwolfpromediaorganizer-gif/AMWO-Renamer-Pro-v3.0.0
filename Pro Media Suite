<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AMWO Renamer | Press & Done 🐺</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C8A84B;
  --gold2: #e8c96b;
  --dark: #0a0a0a;
  --dark2: #0f0f0f;
  --dark3: #161616;
  --purple: #7B2FBE;
  --purple2: #9B4FDE;
  --red: #ff0000;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--dark);
  color: #fff;
  font-family: 'Tajawal', 'Segoe UI', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── خلفية ── */
.bg-layer {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, #2a1a5e44 0%, transparent 60%),
    radial-gradient(ellipse 40% 30% at 80% 80%, #C8A84B0a 0%, transparent 50%),
    radial-gradient(ellipse 60% 40% at 10% 60%, #7B2FBE0a 0%, transparent 50%);
}

.grid-bg {
  position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.03;
  background-image:
    linear-gradient(#C8A84B 1px, transparent 1px),
    linear-gradient(90deg, #C8A84B 1px, transparent 1px);
  background-size: 60px 60px;
}

/* ── هيدر ── */
header {
  position: relative; z-index: 10;
  padding: 28px 40px 0;
  display: flex; align-items: center; justify-content: space-between;
}

.brand {
  display: flex; align-items: center; gap: 12px;
}

.wolf-icon {
  width: 44px; height: 44px;
  background: linear-gradient(135deg, var(--gold), #8a6a1a);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  box-shadow: 0 0 20px #C8A84B44;
}

.brand-text {
  font-size: 0.8rem; color: #555; letter-spacing: 2px; text-transform: uppercase;
}

.nav-badge {
  background: #ffffff08;
  border: 1px solid #ffffff11;
  padding: 8px 18px; border-radius: 50px;
  font-size: 0.85rem; color: #777;
  letter-spacing: 1px;
}

/* ── هيرو ── */
.hero {
  position: relative; z-index: 10;
  text-align: center;
  padding: 70px 20px 50px;
}

.eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: #C8A84B11;
  border: 1px solid #C8A84B33;
  padding: 6px 18px; border-radius: 50px;
  font-size: 0.8rem; color: var(--gold);
  letter-spacing: 2px; text-transform: uppercase;
  margin-bottom: 28px;
  animation: fadeDown 0.8s ease both;
}

.hero h1 {
  font-size: clamp(2.8rem, 7vw, 5.5rem);
  font-weight: 900;
  letter-spacing: 6px;
  line-height: 1.05;
  animation: fadeDown 0.9s ease both;
}

.hero h1 .gold { color: var(--gold); }
.hero h1 .dim  { color: #333; }

.hero-sub {
  font-size: 1.05rem; color: #555;
  letter-spacing: 4px; text-transform: uppercase;
  margin-top: 10px; margin-bottom: 24px;
  animation: fadeDown 1s ease both;
}

.hero-desc {
  max-width: 520px; margin: 0 auto 40px;
  color: #888; font-size: 1.05rem; line-height: 1.9;
  animation: fadeDown 1.1s ease both;
}

/* شريط المميزات */
.features-bar {
  display: inline-flex; align-items: center; gap: 0;
  background: #ffffff05;
  border: 1px solid #ffffff0d;
  border-radius: 50px;
  overflow: hidden;
  margin-bottom: 44px;
  animation: fadeDown 1.2s ease both;
}

.feat-item {
  padding: 10px 22px;
  font-size: 0.82rem; color: #666;
  border-left: 1px solid #ffffff0d;
  white-space: nowrap;
}
.feat-item:last-child { border-left: none; }
.feat-item span { color: var(--gold); margin-left: 6px; }

/* أزرار */
.btn-group {
  display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
  animation: fadeDown 1.3s ease both;
}

.btn {
  padding: 15px 34px;
  border-radius: 50px;
  font-weight: 700; font-size: 1rem;
  text-decoration: none; color: #fff;
  display: inline-flex; align-items: center; gap: 9px;
  border: none; cursor: pointer;
  font-family: 'Tajawal', sans-serif;
  transition: all 0.3s;
  letter-spacing: 0.5px;
}

.btn-main {
  background: linear-gradient(135deg, var(--gold), #8a6a1a);
  box-shadow: 0 4px 28px #C8A84B44;
  color: #000; font-weight: 900;
  animation: pulse-gold 2.5s infinite;
}
.btn-main:hover { transform: scale(1.06); box-shadow: 0 6px 40px #C8A84B66; }

@keyframes pulse-gold {
  0%,100% { box-shadow: 0 4px 28px #C8A84B44; }
  50%      { box-shadow: 0 4px 42px #C8A84B77; }
}

.btn-buy {
  background: linear-gradient(135deg, #1a7a1a, #0d5c0d);
  box-shadow: 0 4px 18px #00c80033;
}
.btn-buy:hover { transform: scale(1.05); box-shadow: 0 6px 28px #00c80055; }

.btn-fb {
  background: linear-gradient(135deg, #1877F2, #1255b5);
  box-shadow: 0 4px 18px #1877F233;
}
.btn-fb:hover { transform: scale(1.05); }

/* ── صورة البرنامج ── */
.app-showcase {
  position: relative; z-index: 10;
  padding: 0 20px 60px;
  display: flex; justify-content: center;
}

.app-frame {
  position: relative;
  max-width: 820px; width: 100%;
}

.app-frame::before {
  content: '';
  position: absolute; inset: -1px;
  background: linear-gradient(135deg, #C8A84B44, #7B2FBE22, #C8A84B11);
  border-radius: 17px;
  z-index: -1;
}

.app-frame::after {
  content: '';
  position: absolute; inset: -30px;
  background: radial-gradient(ellipse at center, #C8A84B11 0%, transparent 70%);
  z-index: -2;
}

.app-img {
  width: 100%;
  border-radius: 14px;
  border: 1px solid #C8A84B22;
  box-shadow:
    0 0 0 1px #ffffff06,
    0 20px 80px #00000099,
    0 0 120px #C8A84B0d;
  transition: transform 0.4s;
  display: block;
}
.app-img:hover { transform: scale(1.008); }

/* شريط عنوان مزيف */
.fake-bar {
  background: #1a1a1a;
  border-radius: 14px 14px 0 0;
  padding: 10px 16px;
  display: flex; align-items: center; gap: 8px;
  border: 1px solid #C8A84B22; border-bottom: none;
}
.dot { width:12px; height:12px; border-radius:50%; }
.dot-r{background:#ff5f57;} .dot-y{background:#ffbd2e;} .dot-g{background:#28c840;}
.bar-title { margin-right: auto; font-size:0.8rem; color:#555; letter-spacing:1px; }
.app-img-wrap {
  border: 1px solid #C8A84B22; border-top:none;
  border-radius: 0 0 14px 14px; overflow:hidden;
}

/* ── قسم المميزات ── */
.section {
  position: relative; z-index: 10;
  padding: 60px 20px;
  max-width: 1000px; margin: 0 auto;
}

.section-label {
  text-align: center;
  font-size: 0.75rem; color: var(--gold);
  letter-spacing: 4px; text-transform: uppercase;
  margin-bottom: 14px;
}

.section-title {
  text-align: center;
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 900; margin-bottom: 50px;
  color: #ddd;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 18px;
}

.feat-card {
  background: #ffffff04;
  border: 1px solid #ffffff09;
  border-radius: 16px;
  padding: 28px 26px;
  transition: all 0.3s;
  position: relative; overflow: hidden;
}

.feat-card::before {
  content: '';
  position: absolute; top: 0; right: 0;
  width: 60px; height: 60px;
  background: radial-gradient(circle at top right, #C8A84B0d, transparent);
}

.feat-card:hover {
  border-color: #C8A84B33;
  background: #C8A84B06;
  transform: translateY(-3px);
  box-shadow: 0 10px 40px #00000055;
}

.feat-icon {
  font-size: 1.8rem; margin-bottom: 14px;
  display: block;
}

.feat-title {
  font-size: 1rem; font-weight: 700; color: #ccc;
  margin-bottom: 8px;
}

.feat-desc {
  font-size: 0.88rem; color: #555; line-height: 1.8;
}

/* ── قسم التسعير ── */
.pricing-wrap {
  display: flex; justify-content: center;
  padding: 20px 20px 80px;
  position: relative; z-index: 10;
}

.price-card {
  background: #0f0f0f;
  border: 1px solid #C8A84B33;
  border-radius: 24px;
  padding: 48px 52px;
  max-width: 420px; width: 100%;
  text-align: center;
  position: relative; overflow: hidden;
  box-shadow: 0 0 80px #C8A84B0d, 0 30px 80px #00000066;
}

.price-card::before {
  content: '';
  position: absolute; top: -1px; left: 20%; right: 20%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.price-badge {
  display: inline-block;
  background: linear-gradient(135deg, var(--gold), #8a6a1a);
  color: #000; font-weight: 900;
  font-size: 0.75rem; letter-spacing: 2px;
  padding: 5px 16px; border-radius: 50px;
  margin-bottom: 24px;
}

.price-amount {
  font-size: 4rem; font-weight: 900;
  color: var(--gold);
  line-height: 1;
  text-shadow: 0 0 40px #C8A84B44;
}
.price-amount sup { font-size: 1.4rem; vertical-align: top; margin-top: 12px; display: inline-block; }
.price-note { color: #444; font-size: 0.85rem; margin-top: 4px; margin-bottom: 28px; }

.price-features { list-style: none; text-align: right; margin-bottom: 32px; }
.price-features li {
  padding: 10px 0;
  border-bottom: 1px solid #ffffff08;
  color: #888; font-size: 0.92rem;
  display: flex; align-items: center; gap: 10px;
}
.price-features li:last-child { border-bottom: none; }
.price-features li .chk { color: var(--gold); font-size: 1rem; }

.trial-note {
  margin-top: 16px;
  font-size: 0.82rem; color: #444;
}
.trial-note strong { color: var(--gold); }

/* ── فوتر ── */
footer {
  position: relative; z-index: 10;
  text-align: center;
  padding: 30px 20px 40px;
  border-top: 1px solid #ffffff07;
}

.footer-wolf { font-size: 1.5rem; margin-bottom: 6px; }
.footer-name { color: var(--gold); font-weight: 700; letter-spacing: 2px; }
.footer-copy { color: #333; font-size: 0.8rem; margin-top: 6px; }

/* ── فاصل ── */
.divider {
  width: 60px; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 0 auto 60px;
  opacity: 0.4;
}

/* ── أنيميشن ── */
@keyframes fadeDown {
  from { opacity:0; transform:translateY(-18px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ── موبايل ── */
@media(max-width:600px){
  header { padding: 20px; }
  .hero { padding: 50px 16px 36px; }
  .feat-item { padding: 8px 14px; font-size:0.75rem; }
  .features-bar { flex-wrap: wrap; border-radius: 16px; }
  .price-card { padding: 36px 28px; }
  .price-amount { font-size: 3rem; }
}
</style>
</head>
